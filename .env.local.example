# ─────────────────────────────────────────────
# RyCal.AI — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Google Gemini API key (required)
# Get yours free at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1M tokens/day — more than enough for personal use
GEMINI_API_KEY=your_gemini_api_key_here

# Nutritionix API (optional but recommended for exact macro data)
# Sign up free at: https://developer.nutritionix.com/
# Free tier: 500 API calls/day
NUTRITIONIX_APP_ID=your_nutritionix_app_id_here
NUTRITIONIX_API_KEY=your_nutritionix_api_key_here
